                if let TypedProvider::Register(_) = self.alloc.stack.peek() {
                        return Ok(());
                    }
                let TypedProvider::Const(value) =
                    self.alloc.stack.pop() else {
                        {
                            ::core::panicking::panic_fmt(format_args!("the top-most stack item was asserted to be a constant value but a register was found"));
                        }
                    };
                self.alloc.stack.push_const(value.reinterpret(ty));
                Ok(())
            }
