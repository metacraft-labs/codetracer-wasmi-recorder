                fn make_branch_cmp_fallback(stack: &mut ValueStack,
                    cmp: Comparator, lhs: Reg, rhs: Reg, offset: BranchOffset)
                    -> Result<Instruction, Error> {
                    let params =
                        stack.alloc_const(ComparatorAndOffset::new(cmp, offset))?;
                    Ok(Instruction::branch_cmp_fallback(lhs, rhs, params))
