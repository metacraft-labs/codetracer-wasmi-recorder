                                        if !!rest.is_empty() {
                                                ::core::panicking::panic("assertion failed: !rest.is_empty()")
                                            };
                                    };
                                self.bump_fuel_consumption(fuel_info, FuelCosts::base)?;
                                self.bump_fuel_consumption(fuel_info,
                                        |costs| { costs.fuel_for_copies(rest.len() as u64 + 3) })?;
