                                        local, returned_value)? {
                            return fallback_case(self, stack, local, value, preserved,
                                    fuel_info);
                        }
                    if let Some(preserved) = preserved {
                            self.bump_fuel_consumption(fuel_info, FuelCosts::base)?;
                            let shifted_last_instr =
                                self.instrs.push_before(last_instr,
                                        Instruction::copy(preserved, local))?;
                            self.notify_preserved_register(last_instr);
                            self.last_instr = Some(shifted_last_instr);
