                make_instr_imm16:
                    fn(result: Reg, lhs: Const16<T>, rhs: Reg) -> Instruction)
                -> Result<bool, Error> where T: Copy + TryInto<Const16<T>> {
                if let Ok(lhs) = lhs.try_into() {
                        let result = self.alloc.stack.push_dynamic()?;
                        self.push_fueled_instr(make_instr_imm16(result, lhs, rhs),
                                FuelCosts::base)?;
