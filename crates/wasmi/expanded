                                return Ok(());
                            }
                        self.push_binary_instr_imm(lhs, rhs, make_instr)
                    }
                    (TypedProvider::Const(lhs), TypedProvider::Register(rhs)) =>
                        {
                        if self.try_push_binary_instr_imm16_rev(T::from(lhs), rhs,
                                        make_instr_imm16_rev)? {
