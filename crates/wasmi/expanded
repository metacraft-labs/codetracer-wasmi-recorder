                            NonZeroT::try_from(T::from(rhs)).ok() else {
                                self.translate_trap(TrapCode::IntegerDivisionByZero)?;
                                return Ok(());
                            };
                        if make_instr_reg_imm_opt(self, lhs, T::from(rhs))? {
                                return Ok(());
                            }
                        if self.try_push_binary_instr_imm16(lhs, non_zero_rhs,
