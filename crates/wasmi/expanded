                            [] => Instruction::Return,
                            [TypedProvider::Register(reg)] =>
                                Instruction::return_reg(*reg),
                            [TypedProvider::Const(value)] =>
                                match value.ty() {
                                    ValType::I32 =>
                                        Instruction::return_imm32(i32::from(*value)),
                                    ValType::I64 =>
