                consteval: fn(input: TypedVal) -> Result<TypedVal, TrapCode>)
                -> Result<(), Error> {
                { if !self.is_reachable() { return Ok(()); } };
                match self.alloc.stack.pop() {
                    TypedProvider::Register(input) => {
                        let result = self.alloc.stack.push_dynamic()?;
                        self.push_fueled_instr(make_instr(result, input),
                                FuelCosts::base)?;
                        Ok(())
                    }
                    TypedProvider::Const(input) =>
                        match consteval(input) {
