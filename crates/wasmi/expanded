                    if let Some(preserved) = preserved {
                            let mut last_instr_uses_preserved = false;
                            for instr in
                                self.instrs.get_slice_at_mut(last_instr).iter_mut() {
                                instr.visit_input_registers(|input|
                                        {
                                            if *input == preserved { last_instr_uses_preserved = true; }
                                        });
