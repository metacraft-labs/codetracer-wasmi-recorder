                                [v0, v1, v2] => {
                                    break
                                        Instruction::register3_ext(stack.provider2reg(v0)?,
                                            stack.provider2reg(v1)?, stack.provider2reg(v2)?);
                                }
                                [v0, v1, v2, rest @ ..] => {
                                    self.instrs.push(Instruction::register_list_ext(stack.provider2reg(v0)?,
                                                stack.provider2reg(v1)?, stack.provider2reg(v2)?))?;
                                    remaining = rest;
                                }
                            };
                        };
