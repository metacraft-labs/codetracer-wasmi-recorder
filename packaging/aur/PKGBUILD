build() {
  cd "$srcdir/codetracer-wasmi-recorder-$pkgver"
  cargo build --release --locked --bin wasmi_cli
}

check() {
  cd "$srcdir/codetracer-wasmi-recorder-$pkgver"
  cargo test --release --locked --bin wasmi_cli || true
}

package() {
  cd "$srcdir/codetracer-wasmi-recorder-$pkgver"
  install -Dm755 "target/release/wasmi_cli" \
